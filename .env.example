# Enable knowledge integration tests (network calls)
KNOWLEDGE_INTEGRATION_TESTS=0

# NVIDIA Embeddings
NVIDIA_EMBEDDINGS_MODEL=nvidia/nv-embed-v1
NVIDIA_EMBEDDINGS_URL=https://integrate.api.nvidia.com/v1/embeddings
NVIDIA_API_KEY=

# SiliconFlow Rerank
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SILICONFLOW_RERANK_URL=https://api.siliconflow.cn/v1/rerank
SILICONFLOW_API_KEY=

# Qdrant (local)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ling_kb